{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=5432;Database=rbac_db;User Id=postgres;Password=123456;"
  },
  "JwtSettings": {
    "Secret": "YourSuperSecretKeyThatIsAtLeast32CharactersLong!",
    "Issuer": "CleanArchitecture.Api",
    "Audience": "CleanArchitecture.Client",
    "AccessTokenExpirationMinutes": 30,
    "RefreshTokenExpirationDays": 7
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "KafkaSettings": {
    "BootstrapServers": "localhost:9092",
    "GroupId": "clean-architecture-group",
    "EnableAutoCommit": false,
    "AutoOffsetReset": "earliest",
    "RequestTimeoutMs": 30000,
    "MaxRetryAttempts": 3,
    "RetryDelayMs": 1000,
    "DlqTopicSuffix": ".dlq",
    "ReplyTopic": "reply-topic",
    "RequestReplyTimeoutMs": 10000
  },
  "CacheSettings": {
    "Provider": "Memory",
    "DefaultTtlMinutes": 60,
    "RedisConnectionString": "localhost:6379"
  },
  "AllowedHosts": "*"
}
